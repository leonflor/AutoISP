# =====================================================
# VARIÁVEIS DE AMBIENTE - ISP Manager
# =====================================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env
# =====================================================

# -----------------------------------------------------
# SUPABASE (Obrigatório)
# -----------------------------------------------------
# Encontre em: Supabase Dashboard → Settings → API
# Estas são chaves PÚBLICAS e seguras para o frontend

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------
# ANALYTICS (Opcional)
# -----------------------------------------------------
# Google Analytics 4 Measurement ID
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel ID
# VITE_META_PIXEL_ID=XXXXXXXXXXXXXXX
